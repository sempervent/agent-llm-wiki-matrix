{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/evaluation.schema.json",
  "title": "Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "subject_ref",
    "rubric_id",
    "scores",
    "weights",
    "total_weighted_score",
    "evaluated_at",
    "evaluator"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "subject_ref": { "type": "string", "minLength": 1 },
    "rubric_id": { "type": "string", "minLength": 1 },
    "scores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "weights": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "total_weighted_score": { "type": "number" },
    "evaluated_at": { "type": "string", "description": "RFC 3339 date-time" },
    "evaluator": { "type": "string", "enum": ["human", "agent", "pipeline"] },
    "notes_markdown": { "type": "string" },
    "scoring_backend": {
      "type": "string",
      "enum": ["deterministic", "semantic_judge", "hybrid"],
      "description": "deterministic=byte-hash; semantic_judge=LLM; hybrid=blend"
    },
    "judge_provenance_relpath": {
      "type": ["string", "null"],
      "description": "Path to evaluation_judge_provenance.json when semantic or hybrid"
    },
    "judge_repeat_count": {
      "oneOf": [
        { "type": "integer", "minimum": 2, "maximum": 32 },
        { "type": "null" }
      ],
      "description": "Semantic judge invocations when >1; null for single-run / deterministic"
    },
    "judge_semantic_aggregation": {
      "oneOf": [
        {
          "type": "string",
          "enum": ["mean", "median", "trimmed_mean"]
        },
        { "type": "null" }
      ],
      "description": "How repeated semantic scores were combined"
    },
    "judge_low_confidence": {
      "oneOf": [
        { "type": "boolean" },
        { "type": "null" }
      ],
      "description": "True when disagreement thresholds flagged instability across repeated runs"
    }
  }
}
