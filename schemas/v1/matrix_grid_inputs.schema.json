{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/matrix_grid_inputs.schema.json",
  "title": "MatrixGridInputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "matrix_id",
    "metric",
    "created_at",
    "entries"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "benchmark_id": { "type": "string" },
    "matrix_id": { "type": "string", "minLength": 1 },
    "metric": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "row_label",
          "col_label",
          "variant_id",
          "prompt_id",
          "evaluation_relpath",
          "total_weighted_score"
        ],
        "properties": {
          "row_label": { "type": "string" },
          "col_label": { "type": "string" },
          "variant_id": { "type": "string" },
          "prompt_id": { "type": "string" },
          "evaluation_relpath": {
            "type": "string",
            "description": "Path to evaluation.json relative to run output root"
          },
          "total_weighted_score": { "type": "number" }
        }
      }
    }
  }
}
