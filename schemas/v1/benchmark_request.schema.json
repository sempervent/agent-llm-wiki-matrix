{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/benchmark_request.schema.json",
  "title": "BenchmarkRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "run_id",
    "cell_id",
    "benchmark_id",
    "variant_id",
    "prompt_id",
    "prompt_text",
    "model",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "cell_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable slug: safe(variant_id)__safe(prompt_id)"
    },
    "benchmark_id": { "type": "string", "minLength": 1 },
    "variant_id": { "type": "string", "minLength": 1 },
    "prompt_id": { "type": "string", "minLength": 1 },
    "prompt_text": { "type": "string" },
    "model": { "type": "string" },
    "temperature": { "type": ["number", "null"] },
    "created_at": { "type": "string", "description": "RFC 3339 date-time" },
    "prompt_source": {
      "type": "string",
      "enum": ["inline", "registry"],
      "description": "Whether prompt_text came from inline definition or prompt registry"
    },
    "prompt_registry_id": {
      "type": ["string", "null"],
      "description": "Registry prompt id when prompt_source is registry"
    },
    "registry_document_version": {
      "type": ["string", "null"],
      "description": "Top-level version field of the registry YAML when resolved from registry"
    },
    "prompt_source_relpath": {
      "type": ["string", "null"],
      "description": "Repo-relative path to the prompt body file when prompt_source is registry"
    },
    "browser_runner": {
      "type": ["string", "null"],
      "description": "Browser runner id when browser evidence augmented the prompt"
    },
    "browser_evidence_relpath": {
      "type": ["string", "null"],
      "description": "Cell-relative path to browser_evidence.json when present"
    }
  }
}
