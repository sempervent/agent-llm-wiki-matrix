{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/matrix_pairwise_inputs.schema.json",
  "title": "MatrixPairwiseInputs",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "matrix_id",
    "metric",
    "created_at",
    "entries"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "benchmark_id": { "type": "string" },
    "matrix_id": { "type": "string", "minLength": 1 },
    "metric": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "row_label",
          "col_label",
          "variant_i",
          "variant_j",
          "mean_abs_score_delta",
          "prompt_ids"
        ],
        "properties": {
          "row_label": { "type": "string" },
          "col_label": { "type": "string" },
          "variant_i": { "type": "string" },
          "variant_j": { "type": "string" },
          "mean_abs_score_delta": { "type": "number" },
          "prompt_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
