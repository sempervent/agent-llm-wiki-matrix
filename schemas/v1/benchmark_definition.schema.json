{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/benchmark_definition.schema.json",
  "title": "BenchmarkDefinitionV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "title", "rubric_ref", "prompts", "variants"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "rubric_ref": { "type": "string", "minLength": 1 },
    "prompt_registry_ref": {
      "type": ["string", "null"],
      "description": "Optional registry YAML path relative to repo root"
    },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/promptItem" }
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/variantSpec" }
    },
    "eval_scoring": {
      "anyOf": [{ "$ref": "#/$defs/evalScoringSpec" }, { "type": "null" }]
    },
    "taxonomy": {
      "description": "Optional task taxonomy (determinism field is the determinism classification)",
      "oneOf": [{ "$ref": "benchmark_taxonomy.schema.json" }, { "type": "null" }]
    },
    "time_budget_seconds": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "token_budget": { "type": ["integer", "null"], "minimum": 1 },
    "retry_policy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_attempts", "backoff_seconds"],
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1, "maximum": 64 },
            "backoff_seconds": { "type": "number", "minimum": 0 }
          }
        },
        { "type": "null" }
      ]
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "expected_artifact_kinds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Pass conditions for external agent comparisons (metadata)"
    },
    "failure_taxonomy_hints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Suggested failure labels for cross-system reports (metadata)"
    }
  },
  "$defs": {
    "promptItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "prompt_ref": { "type": "string", "minLength": 1 },
        "registry_version": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        {
          "required": ["id", "text"],
          "not": { "required": ["prompt_ref"] }
        },
        {
          "required": ["id", "prompt_ref"],
          "not": { "required": ["text"] }
        }
      ]
    },
    "backendSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "model"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["mock", "ollama", "openai_compatible"]
        },
        "model": { "type": "string" }
      }
    },
    "browserBenchConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runner": {
          "type": "string",
          "enum": ["mock", "file", "playwright", "mcp"],
          "default": "mock"
        },
        "scenario_id": { "type": "string", "minLength": 1 },
        "fixture_relpath": { "type": "string", "minLength": 1 },
        "start_url": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "variantSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "agent_stack", "execution_mode", "backend"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "agent_stack": { "type": "string", "minLength": 1 },
        "execution_mode": {
          "type": "string",
          "enum": ["cli", "browser_mock", "repo_governed"]
        },
        "backend": { "$ref": "#/$defs/backendSpec" },
        "browser": { "$ref": "#/$defs/browserBenchConfig" }
      }
    },
    "evalScoringSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend"],
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["deterministic", "semantic_judge", "hybrid"]
        },
        "hybrid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["deterministic_weight", "semantic_weight"],
          "properties": {
            "deterministic_weight": { "type": "number", "minimum": 0, "maximum": 1 },
            "semantic_weight": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "judge_provider_ref": {
          "type": ["string", "null"],
          "description": "Optional providers YAML path relative to repo root for the judge"
        },
        "judge_repeats": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "default": 1,
          "description": "Semantic judge calls per cell; aggregated per criterion"
        },
        "semantic_aggregation": {
          "type": "string",
          "enum": ["mean", "median", "trimmed_mean"],
          "default": "mean"
        },
        "trim_fraction": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.45,
          "default": 0.1
        },
        "judge_max_criterion_range": {
          "anyOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }]
        },
        "judge_max_criterion_stdev": {
          "anyOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }]
        },
        "judge_max_mean_criterion_stdev": {
          "anyOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }]
        },
        "judge_max_total_weighted_stdev": {
          "anyOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }]
        }
      }
    }
  }
}
