{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/manifest.schema.json",
  "title": "BenchmarkRunManifest",
  "description": "Index of a benchmark run output directory (manifest.json). Optional provenance fields may be omitted or null for backward compatibility.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "benchmark_id",
    "title",
    "rubric_ref",
    "created_at",
    "variant_ids",
    "prompt_ids",
    "cells",
    "matrix_grid_path",
    "matrix_pairwise_path",
    "matrix_grid_row_inputs_path",
    "matrix_pairwise_row_inputs_path",
    "report_json_path",
    "report_md_path",
    "matrix_grid_md_path",
    "matrix_pairwise_md_path"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "benchmark_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "rubric_ref": { "type": "string", "minLength": 1 },
    "created_at": {
      "type": "string",
      "description": "RFC 3339 date-time or date string used for the run"
    },
    "variant_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prompt_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "definition_source_relpath": {
      "description": "Benchmark definition path when recorded (CLI); omit or null when unknown",
      "type": ["string", "null"]
    },
    "prompt_registry_effective_ref": {
      "description": "Effective prompt registry YAML when any prompt used prompt_ref; omit or null otherwise",
      "type": ["string", "null"]
    },
    "cells": {
      "type": "array",
      "description": "Per-cell artifact paths; typically sorted lexicographically by cell_id",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "cell_id",
          "request_relpath",
          "raw_response_relpath",
          "normalized_response_relpath",
          "aggregate_response_relpath",
          "evaluation_relpath"
        ],
        "properties": {
          "cell_id": {
            "type": "string",
            "minLength": 1,
            "description": "Stable slug: safe(variant)__safe(prompt)"
          },
          "request_relpath": { "type": "string", "minLength": 1 },
          "raw_response_relpath": { "type": "string", "minLength": 1 },
          "normalized_response_relpath": { "type": "string", "minLength": 1 },
          "aggregate_response_relpath": { "type": "string", "minLength": 1 },
          "evaluation_relpath": { "type": "string", "minLength": 1 },
          "browser_evidence_relpath": {
            "type": ["string", "null"],
            "description": "Cell-relative path to browser_evidence.json for browser_mock cells"
          },
          "judge_provenance_relpath": {
            "type": ["string", "null"],
            "description": "Cell-relative path to evaluation_judge_provenance.json for semantic/hybrid scoring"
          },
          "runtime": {
            "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/benchmarkCellRuntime" }]
          }
        }
      }
    },
    "matrix_grid_path": { "type": "string", "minLength": 1 },
    "matrix_pairwise_path": { "type": "string", "minLength": 1 },
    "matrix_grid_row_inputs_path": { "type": "string", "minLength": 1 },
    "matrix_pairwise_row_inputs_path": { "type": "string", "minLength": 1 },
    "report_json_path": { "type": "string", "minLength": 1 },
    "report_md_path": { "type": "string", "minLength": 1 },
    "matrix_grid_md_path": { "type": "string", "minLength": 1 },
    "matrix_pairwise_md_path": { "type": "string", "minLength": 1 },
    "taxonomy": {
      "description": "Optional taxonomy copied from the benchmark definition",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["taxonomy_version", "task_family", "difficulty", "determinism"],
          "properties": {
            "taxonomy_version": { "type": "integer", "const": 1 },
            "task_family": {
              "type": "string",
              "enum": [
                "repo_governance",
                "runtime_config",
                "documentation",
                "browser_evidence",
                "matrix_reasoning",
                "multi_agent_coordination",
                "campaign",
                "scaffolding",
                "integration",
                "other"
              ]
            },
            "difficulty": {
              "type": "string",
              "enum": ["trivial", "low", "medium", "high", "stress"]
            },
            "determinism": {
              "type": "string",
              "enum": ["deterministic_fixture", "deterministic_scoring", "stochastic_live"]
            },
            "tool_requirements": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "none",
                  "cli",
                  "registry",
                  "browser_mock",
                  "repo_context",
                  "live_llm",
                  "playwright",
                  "compose",
                  "multi_variant"
                ]
              }
            }
          }
        },
        { "type": "null" }
      ]
    },
    "time_budget_seconds": {
      "description": "Optional wall-clock budget hint (seconds)",
      "type": ["number", "null"],
      "exclusiveMinimum": 0
    },
    "token_budget": {
      "description": "Optional token budget hint",
      "type": ["integer", "null"],
      "minimum": 1
    },
    "retry_policy": {
      "description": "Optional retry metadata for agent runners",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["max_attempts", "backoff_seconds"],
          "properties": {
            "max_attempts": { "type": "integer", "minimum": 1, "maximum": 64 },
            "backoff_seconds": { "type": "number", "minimum": 0 }
          }
        },
        { "type": "null" }
      ]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Free-form labels"
    },
    "expected_artifact_kinds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Expected alwm artifact kind names for cell outputs (metadata)"
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Pass conditions for external agent comparisons (metadata)"
    },
    "failure_taxonomy_hints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "description": "Suggested failure labels for cross-system reports (metadata)"
    },
    "comparison_fingerprints": {
      "description": "Stable configuration hashes for cross-run comparison",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/benchmarkComparisonFingerprints" }]
    },
    "runtime_summary": {
      "description": "Wall-clock phase breakdown for the harness run (optional; omitted in older artifacts)",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/benchmarkRunTimingSummary" }]
    },
    "retry_summary": {
      "description": "Judge invocation and parse-fallback rollups (optional)",
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/benchmarkRetrySummary" }]
    }
  },
  "$defs": {
    "benchmarkCellRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "browser_seconds": { "oneOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }] },
        "provider_seconds": { "oneOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }] },
        "evaluation_seconds": { "oneOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }] },
        "judge_seconds": { "oneOf": [{ "type": "null" }, { "type": "number", "minimum": 0 }] },
        "judge_repeat_count": {
          "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 1 }]
        },
        "judge_parse_fallback": { "oneOf": [{ "type": "null" }, { "type": "boolean" }] }
      }
    },
    "benchmarkRunTimingSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "started_at_utc",
        "finished_at_utc",
        "duration_seconds"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "started_at_utc": { "type": "string", "minLength": 1 },
        "finished_at_utc": { "type": "string", "minLength": 1 },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "browser_phase_seconds": { "type": "number", "minimum": 0, "default": 0 },
        "provider_completion_seconds": { "type": "number", "minimum": 0, "default": 0 },
        "evaluation_phase_seconds": { "type": "number", "minimum": 0, "default": 0 },
        "judge_phase_seconds": { "type": "number", "minimum": 0, "default": 0 }
      }
    },
    "benchmarkRetrySummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "retry_policy_max_attempts": {
          "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 1, "maximum": 64 }]
        },
        "total_judge_invocations": { "type": "integer", "minimum": 0, "default": 0 },
        "cells_with_judge_parse_fallback": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },
    "benchmarkComparisonFingerprints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "suite_definition",
        "prompt_set",
        "provider_config",
        "scoring_config",
        "browser_config",
        "prompt_registry_state"
      ],
      "properties": {
        "suite_definition": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "prompt_set": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "provider_config": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "scoring_config": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "browser_config": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "prompt_registry_state": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  }
}
