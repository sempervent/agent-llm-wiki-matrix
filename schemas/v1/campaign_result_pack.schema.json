{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/campaign_result_pack.schema.json",
  "title": "CampaignResultPackV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "layout_version",
    "pack_id",
    "created_at",
    "campaign_id",
    "title",
    "member_depth",
    "artifacts",
    "member_runs",
    "longitudinal_member_glob"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "layout_version": { "type": "integer", "const": 1 },
    "pack_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "source_campaign_relpath": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "campaign_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "campaign_created_at": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "definition_source_relpath": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "fixture_mode_force_mock": { "oneOf": [{ "type": "null" }, { "type": "boolean" }] },
    "campaign_run_count": { "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }] },
    "included_member_count": { "oneOf": [{ "type": "null" }, { "type": "integer", "minimum": 0 }] },
    "alwm_version": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "pack_identity_fingerprint": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 8, "pattern": "^sha256:[a-f0-9]{64}$" }]
    },
    "campaign_definition_fingerprint": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 8, "pattern": "^sha256:[a-f0-9]{64}$" }]
    },
    "campaign_experiment_fingerprints": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/campaignExperimentFingerprints" }]
    },
    "git_commit_sha": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
    "git_describe": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
    "source_campaign_dir": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "member_depth": { "type": "string", "enum": ["full", "manifest"] },
    "longitudinal_member_glob": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "campaign_manifest",
        "campaign_summary_json",
        "campaign_summary_md",
        "campaign_result_pack_json",
        "index_md"
      ],
      "properties": {
        "campaign_manifest": { "type": "string", "minLength": 1 },
        "campaign_summary_json": { "type": "string", "minLength": 1 },
        "campaign_summary_md": { "type": "string", "minLength": 1 },
        "campaign_semantic_summary_json": {
          "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        },
        "campaign_semantic_summary_md": {
          "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        },
        "campaign_comparative_report_md": {
          "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        },
        "campaign_analysis_json": {
          "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        },
        "campaign_dry_run_json": {
          "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
        },
        "campaign_result_pack_json": { "type": "string", "minLength": 1 },
        "index_md": { "type": "string", "minLength": 1 }
      }
    },
    "member_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "run_id",
          "run_index",
          "status",
          "manifest_relpath",
          "suite_ref",
          "benchmark_id"
        ],
        "properties": {
          "run_id": { "type": "string", "minLength": 1 },
          "run_index": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "minLength": 1 },
          "manifest_relpath": { "type": "string", "minLength": 1 },
          "suite_ref": { "type": "string", "minLength": 1 },
          "benchmark_id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "notes": { "oneOf": [{ "type": "null" }, { "type": "string" }] },
    "membership_scope": {
      "description": "all_runs = every campaign manifest member row included; subset = fewer (filters, indices, or failures excluded); unknown = counts missing or ambiguous.",
      "oneOf": [
        { "type": "null" },
        { "type": "string", "enum": ["all_runs", "subset", "unknown"] }
      ]
    },
    "optional_layers_present": {
      "description": "Optional artifact layers bundled: semantic_summary, comparative_report, comparative_analysis, dry_run_plan.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "semantic_summary",
              "comparative_report",
              "comparative_analysis",
              "dry_run_plan"
            ]
          }
        }
      ]
    }
  },
  "$defs": {
    "campaignExperimentFingerprints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "campaign_definition",
        "suite_definitions",
        "provider_configs",
        "scoring_configs",
        "browser_configs",
        "prompt_registry_state"
      ],
      "properties": {
        "campaign_definition": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "suite_definitions": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "provider_configs": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "scoring_configs": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "browser_configs": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "prompt_registry_state": {
          "type": "string",
          "minLength": 8,
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    }
  }
}
