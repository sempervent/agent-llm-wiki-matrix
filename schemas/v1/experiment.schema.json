{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/experiment.schema.json",
  "title": "Experiment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "hypothesis",
    "protocol_markdown",
    "parameters",
    "status",
    "started_at",
    "tags"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "hypothesis": { "type": "string" },
    "protocol_markdown": { "type": "string" },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "string", "boolean"]
      }
    },
    "status": {
      "type": "string",
      "enum": ["planned", "running", "completed", "aborted"],
      "default": "planned"
    },
    "started_at": { "type": "string", "description": "RFC 3339 date-time" },
    "ended_at": { "type": "string", "description": "RFC 3339 date-time" },
    "tags": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
