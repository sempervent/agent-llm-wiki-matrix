{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/browser_evidence.schema.json",
  "title": "BrowserEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "navigation_sequence"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "navigation_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "action": {
            "type": "string",
            "description": "High-level action label (navigate, click, submit, ...)"
          }
        }
      }
    },
    "console_messages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["level", "text"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["log", "warn", "error", "debug"]
          },
          "text": { "type": "string" }
        }
      },
      "default": []
    },
    "dom_snapshot_ref": {
      "type": "string",
      "description": "Opaque id or repo-relative path to a full DOM snapshot artifact (optional; distinct from dom_excerpts)."
    },
    "dom_excerpts": {
      "type": "array",
      "description": "Fixture-backed snippets of visible text and/or HTML aligned to selectors (auditor-friendly grounding).",
      "items": { "$ref": "#/$defs/domExcerpt" },
      "default": []
    },
    "screenshots": {
      "type": "array",
      "description": "Metadata for captured screenshots (paths may point at committed assets or placeholders; hashes support integrity).",
      "items": { "$ref": "#/$defs/screenshotMetadata" },
      "default": []
    },
    "extensions": {
      "description": "Optional structured JSON bag for runner-specific or experiment fields. Known keys (network, accessibility) are rendered readably in prompts; other keys remain JSON.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "fixture_profile": { "type": "string" },
            "structured_capture_version": { "type": "integer" },
            "runner": { "type": "string" },
            "trace_digest": { "type": "string" },
            "network": { "$ref": "#/$defs/networkSummary" },
            "accessibility": { "$ref": "#/$defs/accessibilitySummary" },
            "performance": { "$ref": "#/$defs/performanceHints" }
          }
        }
      ]
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "domExcerpt": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "allOf": [
        {
          "anyOf": [
            { "required": ["visible_text"] },
            { "required": ["html_snippet"] }
          ]
        }
      ],
      "properties": {
        "label": {
          "type": "string",
          "description": "Human-readable label for this excerpt (e.g. primary CTA)."
        },
        "selector": {
          "type": "string",
          "description": "CSS selector or accessibility hint when known."
        },
        "aria_role": {
          "type": "string",
          "description": "ARIA role when known (e.g. button, link)."
        },
        "accessibility_name": {
          "type": "string",
          "description": "Accessible name / computed label."
        },
        "dom_order": {
          "type": "integer",
          "minimum": 0,
          "description": "Stable document-order index for grounding (optional)."
        },
        "visible_text": {
          "type": "string",
          "minLength": 1,
          "description": "Visible text as captured from the DOM."
        },
        "html_snippet": {
          "type": "string",
          "minLength": 1,
          "description": "Small HTML fragment for auditors (escape carefully; fixtures should avoid PII)."
        }
      }
    },
    "screenshotMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "allOf": [
        {
          "anyOf": [{ "required": ["relpath"] }, { "required": ["content_sha256"] }]
        }
      ],
      "properties": {
        "relpath": {
          "type": "string",
          "minLength": 1,
          "description": "Repo-relative path to an image or sidecar metadata file when committed."
        },
        "content_sha256": {
          "type": "string",
          "minLength": 8,
          "pattern": "^[a-f0-9]{64}$",
          "description": "Hex SHA-256 of image bytes when known (no 0x prefix)."
        },
        "capture_scope": {
          "type": "string",
          "enum": ["viewport", "full_page", "element"],
          "description": "Captured region: viewport, full scroll, or a single element."
        },
        "target_selector": {
          "type": "string",
          "minLength": 1,
          "description": "When capture_scope is element, selector or a11y hint."
        },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "description": "Shot order within the session (0-based)."
        },
        "device_pixel_ratio": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Device pixel ratio (e.g. 2.0)."
        },
        "viewport_width": { "type": "integer", "minimum": 1 },
        "viewport_height": { "type": "integer", "minimum": 1 },
        "mime_type": { "type": "string", "minLength": 1 },
        "caption": { "type": "string" },
        "captured_at": {
          "type": "string",
          "description": "RFC 3339 timestamp when the screenshot was taken (fixture or live)."
        }
      }
    },
    "networkSummary": {
      "type": "object",
      "additionalProperties": false,
      "description": "Deterministic summary of network activity (fixture or live).",
      "properties": {
        "requests_total": { "type": "integer", "minimum": 0 },
        "failed_requests": { "type": "integer", "minimum": 0 },
        "last_url": { "type": "string" },
        "last_status_code": { "type": "integer", "minimum": 100, "maximum": 599 }
      }
    },
    "accessibilitySummary": {
      "type": "object",
      "additionalProperties": false,
      "description": "High-level a11y signals for auditors (not a full axe report).",
      "properties": {
        "violations_count": { "type": "integer", "minimum": 0 },
        "rules_checked": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },
    "performanceHints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional coarse timing hints (milliseconds).",
      "properties": {
        "dom_content_loaded_ms": { "type": "number", "minimum": 0 },
        "largest_contentful_paint_ms": { "type": "number", "minimum": 0 }
      }
    }
  }
}
