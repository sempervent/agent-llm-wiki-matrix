{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sempervent/agent-llm-wiki-matrix/schemas/v1/evaluation_judge_provenance.schema.json",
  "title": "EvaluationJudgeProvenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "evaluation_ref",
    "subject_ref",
    "rubric_id",
    "scoring_backend",
    "judge_system_prompt",
    "judge_user_prompt",
    "provider",
    "raw_response_text",
    "parsed_criterion_scores",
    "parse_ok"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "evaluation_id": { "type": "string", "minLength": 1 },
    "evaluation_ref": {
      "type": "string",
      "minLength": 1,
      "description": "Path to evaluation.json relative to benchmark run root"
    },
    "subject_ref": { "type": "string", "minLength": 1 },
    "rubric_id": { "type": "string", "minLength": 1 },
    "scoring_backend": {
      "type": "string",
      "enum": ["semantic_judge", "hybrid"]
    },
    "judge_system_prompt": { "type": "string" },
    "judge_user_prompt": { "type": "string" },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "model"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["mock", "ollama", "openai_compatible"]
        },
        "model": { "type": "string", "minLength": 1 }
      }
    },
    "raw_response_text": { "type": "string" },
    "parsed_criterion_scores": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "parse_ok": { "type": "boolean" },
    "parse_error": { "type": ["string", "null"] },
    "hybrid_aggregation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "deterministic_weight",
        "semantic_weight",
        "deterministic_scores",
        "semantic_scores",
        "blend_method"
      ],
      "properties": {
        "deterministic_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "semantic_weight": { "type": "number", "minimum": 0, "maximum": 1 },
        "deterministic_scores": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "semantic_scores": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "blend_method": { "type": "string", "const": "weighted_per_criterion" },
        "semantic_repeat_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "description": "Semantic judge runs aggregated before blending with deterministic scores"
        }
      }
    },
    "aggregation_notes": { "type": ["string", "null"] },
    "repeat_aggregation": {
      "description": "Present when multiple semantic judge runs were aggregated",
      "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/judgeRepeatAggregation" }]
    }
  },
  "$defs": {
    "judgeCriterionDisagreement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max", "score_range", "stdev"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "score_range": { "type": "number" },
        "stdev": { "type": "number" }
      }
    },
    "judgeDisagreementSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "per_criterion",
        "mean_stdev_across_criteria",
        "total_weighted_per_run",
        "total_weighted_stdev",
        "max_range_across_criteria"
      ],
      "properties": {
        "per_criterion": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/judgeCriterionDisagreement" }
        },
        "mean_stdev_across_criteria": { "type": "number" },
        "total_weighted_per_run": {
          "type": "array",
          "items": { "type": "number" }
        },
        "total_weighted_stdev": { "type": "number" },
        "max_range_across_criteria": { "type": "number" }
      }
    },
    "judgeRepeatConfidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low_confidence", "flags", "thresholds"],
      "properties": {
        "low_confidence": { "type": "boolean" },
        "flags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [{ "type": "number" }, { "type": "null" }]
          }
        }
      }
    },
    "judgeRepeatRunRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_index",
        "raw_response_text",
        "parsed_criterion_scores",
        "parse_ok"
      ],
      "properties": {
        "run_index": { "type": "integer", "minimum": 0 },
        "raw_response_text": { "type": "string" },
        "parsed_criterion_scores": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "parse_ok": { "type": "boolean" },
        "parse_error": { "type": ["string", "null"] }
      }
    },
    "judgeRepeatAggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repeat_count",
        "strategy",
        "trim_fraction",
        "runs",
        "aggregated_semantic_scores",
        "disagreement",
        "confidence"
      ],
      "properties": {
        "repeat_count": { "type": "integer", "minimum": 1, "maximum": 32 },
        "strategy": {
          "type": "string",
          "enum": ["mean", "median", "trimmed_mean"]
        },
        "trim_fraction": { "type": "number", "minimum": 0, "maximum": 0.45 },
        "runs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/judgeRepeatRunRecord" }
        },
        "aggregated_semantic_scores": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "disagreement": { "$ref": "#/$defs/judgeDisagreementSummary" },
        "confidence": { "$ref": "#/$defs/judgeRepeatConfidence" }
      }
    }
  }
}
