# Copy to .env and adjust. Used by Docker Compose and local CLI.

# Logging: DEBUG, INFO, WARNING, ERROR
ALWM_LOG_LEVEL=INFO

# Deterministic fixture mode (no live network; use bundled fixtures)
ALWM_FIXTURE_MODE=0

# Provider selection: mock | ollama | openai_compatible (Phase 3)
ALWM_PROVIDER=mock

# Optional YAML merged before env overrides (see config/providers.example.yaml)
# ALWM_PROVIDER_CONFIG=config/providers.yaml

# Ollama (when ALWM_PROVIDER=ollama)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=gpt-oss:20b

# Host directory bind-mounted as the Ollama container's /root/.ollama (see docker-compose.yml: ollama)
# Pull after `docker compose --profile benchmark-ollama up -d ollama`, e.g.:
#   docker compose --profile benchmark-ollama exec ollama ollama pull gpt-oss:20b
# OLLAMA_MODELS_DIR=./.ollama-models

# OpenAI-compatible / llama.cpp HTTP (when ALWM_PROVIDER=openai_compatible)
OPENAI_BASE_URL=http://host.docker.internal:8080/v1
OPENAI_API_KEY=not-needed-local

# Compose profile benchmark-llamacpp (override if llama-server listens elsewhere)
# LLAMACPP_OPENAI_BASE_URL=http://host.docker.internal:8080/v1

# Live benchmark integration tests (pytest tests/integration) — off by default
# ALWM_LIVE_BENCHMARK_OLLAMA=1
# ALWM_LIVE_BENCHMARK_LLAMACPP=1

# Playwright integration tests (tests/integration/test_playwright_browser.py) — off by default
# ALWM_PLAYWRIGHT_SMOKE=1

# Repo-relative paths (override in CI/containers)
ALWM_REPO_ROOT=.
