# Copy to .env and adjust. Used by Docker Compose and local CLI.

# Logging: DEBUG, INFO, WARNING, ERROR
ALWM_LOG_LEVEL=INFO

# Deterministic fixture mode (no live network; use bundled fixtures)
ALWM_FIXTURE_MODE=0

# Provider selection: mock | ollama | openai_compatible (Phase 3)
ALWM_PROVIDER=mock

# Ollama (when ALWM_PROVIDER=ollama)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# OpenAI-compatible / llama.cpp HTTP (when ALWM_PROVIDER=openai_compatible)
OPENAI_BASE_URL=http://host.docker.internal:8080/v1
OPENAI_API_KEY=not-needed-local

# Repo-relative paths (override in CI/containers)
ALWM_REPO_ROOT=.
